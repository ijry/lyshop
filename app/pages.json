{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u--(.*)": "uview-plus/components/u-$1/u-$1.vue",
      "^up-(.*)": "uview-plus/components/u-$1/u-$1.vue",
      "^u-([^-].*)": "uview-plus/components/u-$1/u-$1.vue"
    }
  },
  "pages": [
    { "path": "pages/index/index",          "style": { "navigationBarTitleText": "%pages.index.title%" } },
    { "path": "pages/product/list",         "style": { "navigationBarTitleText": "%pages.product.list%" } },
    { "path": "pages/product/detail",       "style": { "navigationBarTitleText": "%pages.product.detail%" } },
    { "path": "pages/cart/index",           "style": { "navigationBarTitleText": "%pages.cart.index%" } },
    { "path": "pages/order/confirm",        "style": { "navigationBarTitleText": "%pages.order.confirm%" } },
    { "path": "pages/order/list",           "style": { "navigationBarTitleText": "%pages.order.list%" } },
    { "path": "pages/order/detail",         "style": { "navigationBarTitleText": "%pages.order.detail%" } },
    { "path": "pages/order/after-sale-apply",  "style": { "navigationBarTitleText": "%pages.order.afterSaleApply%" } },
    { "path": "pages/order/after-sale-detail", "style": { "navigationBarTitleText": "%pages.order.afterSaleDetail%" } },
    { "path": "pages/order/review",         "style": { "navigationBarTitleText": "%pages.order.review%" } },
    { "path": "pages/marketing/coupon",     "style": { "navigationBarTitleText": "%pages.marketing.coupon%" } },
    { "path": "pages/marketing/seckill",    "style": { "navigationBarTitleText": "%pages.marketing.seckill%" } },
    { "path": "pages/marketing/group-buy",  "style": { "navigationBarTitleText": "%pages.marketing.groupBuy%" } },
    { "path": "pages/marketing/bargain",    "style": { "navigationBarTitleText": "%pages.marketing.bargain%" } },
    { "path": "pages/im/chat",              "style": { "navigationBarTitleText": "%pages.im.chat%", "navigationBarBackgroundColor": "#ffffff" } },
    { "path": "pages/user/index",           "style": { "navigationBarTitleText": "%pages.user.index%", "navigationStyle": "custom" } },
    { "path": "pages/user/security",        "style": { "navigationBarTitleText": "%pages.user.security%" } },
    { "path": "pages/user/favorites",       "style": { "navigationBarTitleText": "%pages.user.favorites%" } },
    { "path": "pages/user/address",         "style": { "navigationBarTitleText": "%pages.user.address%" } },
    { "path": "pages/user/points",          "style": { "navigationBarTitleText": "%pages.user.points%" } },
    { "path": "pages/user/vip",             "style": { "navigationBarTitleText": "%pages.user.vip%" } },
    { "path": "pages/message/index",        "style": { "navigationBarTitleText": "%pages.message.index%" } },
    { "path": "pages/message/list",         "style": { "navigationBarTitleText": "%pages.message.list%" } },
    { "path": "pages/checkin/index",        "style": { "navigationBarTitleText": "%pages.checkin.index%" } },
    { "path": "pages/login/index",          "style": { "navigationBarTitleText": "%pages.login.index%" } }
  ],
  "tabBar": {
    "color": "#666666",
    "selectedColor": "#dc2626",
    "backgroundColor": "#ffffff",
    "borderStyle": "black",
    "list": [
      { "pagePath": "pages/index/index",   "text": "%tabBar.home%" },
      { "pagePath": "pages/product/list",  "text": "%tabBar.products%" },
      { "pagePath": "pages/cart/index",    "text": "%tabBar.cart%" },
      { "pagePath": "pages/order/list",    "text": "%tabBar.orders%" },
      { "pagePath": "pages/user/index",    "text": "%tabBar.me%" }
    ]
  },
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarBackgroundColor": "#FFFFFF",
    "backgroundColor": "#F8FAFC"
  }
}
