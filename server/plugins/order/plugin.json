{
  "name": "order",
  "title": "订单插件",
  "version": "1.0.0",
  "description": "购物车、订单、支付、售后",
  "author": "lyshop",
  "depends": ["product"],
  "menus": [
    {
      "title": "订单管理", "title_key": "menu.order",
      "icon": "shopping-cart",
      "path": "/order",
      "sort": 20,
      "children": [
        { "title": "订单列表", "title_key": "menu.order.list", "path": "/order/list", "permission": "order:view" },
        { "title": "售后列表", "title_key": "menu.order.afterSale", "path": "/order/after-sale/list", "permission": "order:view" }
      ]
    },
    {
      "title": "评价管理", "title_key": "menu.review",
      "icon": "star",
      "path": "/review",
      "sort": 21,
      "children": [
        { "title": "评价列表", "title_key": "menu.review.list", "path": "/review/list", "permission": "order:view" }
      ]
    }
  ],
  "permissions": ["order:view", "order:ship", "order:refund", "order:review-reply"]
}
