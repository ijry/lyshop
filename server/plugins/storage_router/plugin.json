{
  "name": "storage_router",
  "title": "存储路由",
  "version": "1.0.0",
  "description": "配置默认上传驱动并支持上传时按参数指定驱动",
  "author": "lyshop",
  "depends": [],
  "menus": [],
  "permissions": ["system:config"],
  "config_items": [
    {
      "key": "default_driver",
      "label": "默认上传驱动",
      "type": "select",
      "required": true,
      "options": [
        { "label": "本地存储", "value": "local" },
        { "label": "阿里云 OSS", "value": "oss" },
        { "label": "腾讯云 COS", "value": "cos" },
        { "label": "七牛云", "value": "qiniu" }
      ]
    }
  ]
}
